# ============================================================
# NOVALIS - Configuration
# ============================================================
# Copie ce fichier en .env et remplis tes clés

# --- ANTHROPIC (Claude API) ---
# Créer un compte: https://console.anthropic.com
# Aller dans API Keys > Create Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# --- TWILIO (SMS + Téléphone) ---
# Créer un compte: https://www.twilio.com/try-twilio
# Les infos sont dans le Dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+18191234567

# --- TON COMMERCE ---
BUSINESS_NAME=Salon Harmonie
BUSINESS_TYPE=Salon de coiffure
BUSINESS_SERVICES=Coupe femme (45$), Coupe homme (25$), Coloration (75$), Balayage (95$)
BUSINESS_HOURS=Mardi-Samedi 9h-17h, fermé dimanche et lundi
BUSINESS_ADDRESS=123 rue Wellington Nord, Sherbrooke QC
BUSINESS_INFO=Stationnement gratuit. Sur rendez-vous seulement.

# --- TON NUMÉRO (pour recevoir les alertes) ---
OWNER_PHONE=+1819xxxxxxx

# --- FACEBOOK MESSENGER (optionnel) ---
# Voir le guide d'installation pour la configuration Facebook
FB_VERIFY_TOKEN=novalis_verify_token
FB_PAGE_ACCESS_TOKEN=
