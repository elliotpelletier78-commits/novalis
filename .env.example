# ============================================================
# NOVALIS V3 - Configuration Plateforme Multi-Tenant
# ============================================================
# Copie ce fichier en .env et remplis tes clés

# --- ANTHROPIC (Claude API) ---
# Créer un compte: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# --- TWILIO (SMS + Téléphone) ---
# Créer un compte: https://www.twilio.com/try-twilio
# Note V3: Le numéro Twilio est maintenant configuré par client
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxx

# --- ADMIN PLATEFORME ---
ADMIN_USER=admin
ADMIN_PASS=novalis2024
PLATFORM_SECRET=your-secret-key-here

# --- CORS ---
ALLOWED_ORIGINS=*

# --- FACEBOOK MESSENGER ---
FB_VERIFY_TOKEN=novalis_verify_token

# --- BASE DE DONNÉES ---
DATABASE_PATH=novalis.db
